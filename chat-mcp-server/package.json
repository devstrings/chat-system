{
    "name": "chat-mcp-server",
    "version": "1.0.0",
    "description": "MCP server for DevStrings Chat System — exposes messages, groups, and search to Claude",
    "main": "src/index.js",
    "type": "module",
    "bin": {
        "chat-mcp": "./src/index.js"
    },
    "scripts": {
        "start": "node src/index.js",
        "start:http": "node src/index.js --transport=http",
        "start:stdio": "node src/index.js --transport=stdio",
        "dev": "nodemon src/index.js"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "axios": "^1.6.0",
        "express": "^4.18.2",
        "dotenv": "^16.3.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "nodemon": "^3.0.2"
    },
    "imports": {
        "#config": "./config/index.js",
        "#src": "./src/*.js"
    }
}